  "item": [
    {
      "name": "Get all bugs",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Response is an array\", () => {\r",
              "\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response).to.be.an(\"array\");\r",
              "\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Bug has required fields\", () => {\r",
              "\r",
              "    const bug = pm.response.json()[0];\r",
              "\r",
              "    pm.expect(bug).to.have.property(\"id\");\r",
              "    pm.expect(bug).to.have.property(\"title\");\r",
              "    pm.expect(bug).to.have.property(\"priority\");\r",
              "    pm.expect(bug).to.have.property(\"status\");\r",
              "\r",
              "    const bugs = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set(\"existingBugId\", bugs[0].id);\r",
              "\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/bugs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "bugs"
          ]
        }
      },
      "response": []
    },
