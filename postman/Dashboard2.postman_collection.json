      "name": "Create bug",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", () => {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Created bug has correct title\", () => {\r",
              "\r",
              "    const bug = pm.response.json();\r",
              "\r",
              "    pm.expect(bug.title)\r",
              "        .to.eql(\"API login failure\");\r",
              "\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Created bug has OPEN status\", () => {\r",
              "\r",
              "    const bug = pm.response.json();\r",
              "\r",
              "    pm.expect(bug.status)\r",
              "        .to.eql(\"OPEN\");\r",
              "\r",
              "});\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set(\r",
              "    \"bugId\",\r",
              "    response.id\r",
              ");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
