              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Correct bug returned\", function () {\r",
              "    pm.expect(response.id).to.eql(\r",
              "        Number(pm.collectionVariables.get(\"existingBugId\"))\r",
              "    );\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
